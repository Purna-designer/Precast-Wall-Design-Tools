<UserControl x:Class="PrecastConnectionApp.Views.ProjectSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:PrecastConnectionApp.ViewModels"
             Background="Transparent">
    <Grid Margin="30" MaxWidth="750" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Head -->
        <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel>
                <TextBlock FontSize="15" FontWeight="Medium" Foreground="{StaticResource Theme.Ink}" Margin="0,0,0,4">
                    <Run Text="Pier Summary — Data Import" />
                </TextBlock>
                <TextBlock Text="Import raw forces from ETABS or Excel to populate the pier summary table." FontSize="13" Foreground="{StaticResource Theme.Muted}" TextWrapping="Wrap" MaxWidth="560" HorizontalAlignment="Left"/>
            </StackPanel>

            <Button Grid.Column="1" Command="{Binding ViewRawDataCommand}" Style="{StaticResource ActionButtonStyle}" Padding="14,7" VerticalAlignment="Bottom" Cursor="Hand">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Data="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" 
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" Fill="Transparent"/>
                            <Ellipse Canvas.Left="9" Canvas.Top="9" Width="6" Height="6" 
                                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" Fill="Transparent"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="View Pier Forces Data" FontWeight="Medium" FontSize="12.5" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Toolbar / Import Controls -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,20">
            <StackPanel>
                <Border Background="{StaticResource CardHeaderBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,9" Margin="-18,-18,-18,12" CornerRadius="8,8,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="3" Height="13" Background="{StaticResource PrimaryBlueBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="DATA SOURCE" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MenuTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton Content="Extract from ETABS" IsChecked="{Binding IsExtractEtabs}" Margin="0,0,20,0" Foreground="{StaticResource Theme.Ink}"/>
                    <RadioButton Content="Import from Excel" IsChecked="{Binding IsImportExcel}" Foreground="{StaticResource Theme.Ink}"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="96" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource Theme.Ink}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="ETABS File (.edb):"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImportExcel}" Value="True">
                                        <Setter Property="Text" Value="Excel File (.xlsx):"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Grid.Column="1" Text="{Binding EtabsFilePath, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource InputBox}" Margin="0,0,10,0" VerticalAlignment="Center" Width="300" Height="28">
                        <TextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="ApplicationCommands.Cut" Header="Cut" />
                                <MenuItem Command="ApplicationCommands.Copy" Header="Copy" />
                                <MenuItem Command="ApplicationCommands.Paste" Header="Paste" />
                            </ContextMenu>
                        </TextBox.ContextMenu>
                    </TextBox>
                    
                    <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseCommand}" 
                            Style="{StaticResource ActionButtonStyle}" Margin="0,0,15,0" VerticalAlignment="Center" Height="28"/>
                            
                    <!-- Extract options -->
                    <ComboBox Grid.Column="3" Width="110" Height="28" Margin="0,0,10,0" VerticalContentAlignment="Center" 
                              SelectedIndex="{Binding ExtractModeIndex}"
                              IsEnabled="{Binding IsExtractEtabs}">
                        <ComboBoxItem Content="Run &amp; Extract" />
                        <ComboBoxItem Content="Extract Only" />
                    </ComboBox>

                    <Button Grid.Column="4" Command="{Binding ExtractCommand}" VerticalAlignment="Center" Height="28" Padding="16,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
                                <Setter Property="Content" Value="Extract Data"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImportExcel}" Value="True">
                                        <Setter Property="Content" Value="Import Excel"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Pier Summaries DataGrid -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Table Header with Search and Filter -->
                <Border Grid.Row="0" Background="{StaticResource CardHeaderBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="3" Height="13" Background="{StaticResource PrimaryBlueBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="PIER SUMMARY" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MenuTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Background="{StaticResource GhostBlueBrush}" CornerRadius="10" Padding="8,2" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="{Binding FilterCountText}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBlueBrush}"/>
                            </Border>
                            <!-- Dashboard Counts -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="{Binding SafeCount, StringFormat='SAFE: {0}'}" FontSize="10" FontWeight="SemiBold" Foreground="#166534" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ReviewCount, StringFormat='REVIEW: {0}'}" FontSize="10" FontWeight="SemiBold" Foreground="#92400E" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding UnsafeCount, StringFormat='UNSAFE: {0}'}" FontSize="10" FontWeight="SemiBold" Foreground="#991B1B" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding PendingCount, StringFormat='PENDING: {0}'}" FontSize="10" FontWeight="SemiBold" Foreground="#4B5563"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            
                            <Border Background="White" BorderBrush="#A0A0A0" BorderThickness="1" CornerRadius="4" Margin="0,5,8,5" Padding="6,2">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Ellipse Canvas.Left="4" Canvas.Top="4" Width="14" Height="14" 
                                                     Stroke="#9CA3AF" StrokeThickness="2" Fill="Transparent"/>
                                            <Line X1="21" Y1="21" X2="16.65" Y2="16.65" 
                                                  Stroke="#9CA3AF" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    
                                    <Grid VerticalAlignment="Center" Margin="0,0,0,1">
                                        <TextBlock Text="Search piers..." Foreground="#9CA3AF" FontSize="12" IsHitTestVisible="False" VerticalAlignment="Center" Margin="2,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox x:Name="SearchTextBox" Background="Transparent" BorderThickness="0" Width="120" FontSize="12" Foreground="#374151" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Button x:Name="FilterButton" Command="{Binding ToggleFilterPopupCommand}" Style="{StaticResource ActionButtonStyle}" FontSize="12" Padding="11,5" Cursor="Hand">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M4,6 H20 M8,12 H16 M11,18 H13" 
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Filter" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>

                            <Popup x:Name="FilterPopup" IsOpen="{Binding IsFilterPopupOpen}" StaysOpen="False" PlacementTarget="{Binding ElementName=FilterButton}" Placement="Bottom" HorizontalOffset="-250" VerticalOffset="8" AllowsTransparency="True">
                                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Margin="0,0,15,15">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="12" Direction="270" ShadowDepth="4"/>
                                    </Border.Effect>
                                    <Grid Width="400" Height="280">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <!-- Header -->
                                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="15,10">
                                            <Grid>
                                                <TextBlock Text="Filter Pier Summaries" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                                <Button Content="Clear All" Command="{Binding ClearFiltersCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#3B82F6" Cursor="Hand" FontWeight="SemiBold"/>
                                            </Grid>
                                        </Border>
                                        <!-- Content -->
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Left Menu -->
                                            <Border BorderBrush="#E5E7EB" BorderThickness="0,0,1,0" Background="#F9FAFB">
                                                <ListBox ItemsSource="{Binding FilterGroups}" SelectedItem="{Binding SelectedFilterGroup}" Background="Transparent" BorderThickness="0" Margin="0,5">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ColumnName}" Padding="10,6" Foreground="#4B5563" FontWeight="Medium"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsSelected" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                                                                <Setter TargetName="Bd" Property="BorderThickness" Value="3,0,0,0"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                </ListBox>
                                            </Border>
                                            <!-- Right Checkboxes -->
                                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding SelectedFilterGroup.Items}" Margin="15,10">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,5" Foreground="#374151" FontSize="12"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Popup>
                            
                        </StackPanel>
                    </Grid>
                </Border>

            <DataGrid x:Name="PierGrid" Grid.Row="1" ItemsSource="{Binding WallView}" AutoGenerateColumns="False" 
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      Style="{StaticResource StandardDataGridStyle}" Background="Transparent"
                      HeadersVisibility="Column" GridLinesVisibility="All" RowHeight="40" BorderThickness="0"
                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PIER LABEL" Binding="{Binding Label}" Width="*" MinWidth="100" />
                    <DataGridTextColumn Header="STORY" Binding="{Binding Story}" Width="*" MinWidth="100" />
                    <DataGridTextColumn Header="FINAL PT (%)" Binding="{Binding FinalPt, StringFormat={}{0:F2}}" Width="Auto" MinWidth="100" />
                    <DataGridTemplateColumn Header="STATUS" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="StatusBorder" Background="#DCFCE7" CornerRadius="10" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="StatusText" Text="{Binding Status}" Foreground="#166534" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Unsafe">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#FEE2E2"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#991B1B"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Review">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#FEF3C7"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#92400E"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="View Design &#x2192;" Command="{Binding DataContext.ViewDetailedDesignCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        FontSize="11.5" FontWeight="Medium" HorizontalAlignment="Left" Padding="12,5" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
