<Window x:Class="PrecastConnectionApp.Views.ForcesPopupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pier Forces Data" Height="600" Width="1000" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Theme.Paper}" FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Search and Filter -->
        <Border Grid.Row="0" Background="{StaticResource CardHeaderBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="3" Height="13" Background="{StaticResource PrimaryBlueBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="RAW PIER FORCES DATA" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MenuTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Background="{StaticResource GhostBlueBrush}" CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FilterCountText}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBlueBrush}"/>
                    </Border>
                </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            
                            <Border Background="White" BorderBrush="#A0A0A0" BorderThickness="1" CornerRadius="4" Margin="0,5,8,5" Padding="6,2">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Ellipse Canvas.Left="4" Canvas.Top="4" Width="14" Height="14" 
                                                     Stroke="#9CA3AF" StrokeThickness="2" Fill="Transparent"/>
                                            <Line X1="21" Y1="21" X2="16.65" Y2="16.65" 
                                                  Stroke="#9CA3AF" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    
                                    <Grid VerticalAlignment="Center" Margin="0,0,0,1">
                                        <TextBlock Text="Search members..." Foreground="#9CA3AF" FontSize="12" IsHitTestVisible="False" VerticalAlignment="Center" Margin="2,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox x:Name="SearchTextBox" Background="Transparent" BorderThickness="0" Width="120" FontSize="12" Foreground="#374151" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Button x:Name="FilterButton" Command="{Binding ToggleFilterPopupCommand}" Style="{StaticResource ActionButtonStyle}" FontSize="12" Padding="11,5" Cursor="Hand" Margin="0,5,0,5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M4,6 H20 M8,12 H16 M11,18 H13" 
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Filter" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>

                            <Popup x:Name="FilterPopup" IsOpen="{Binding IsFilterPopupOpen}" StaysOpen="False" PlacementTarget="{Binding ElementName=FilterButton}" Placement="Bottom" HorizontalOffset="-250" VerticalOffset="8" AllowsTransparency="True">
                                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Margin="0,0,15,15">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="12" Direction="270" ShadowDepth="4"/>
                                    </Border.Effect>
                                    <Grid Width="400" Height="280">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <!-- Header -->
                                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="15,10">
                                            <Grid>
                                                <TextBlock Text="Filter Data" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                                <Button Content="Clear All" Command="{Binding ClearFiltersCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#3B82F6" Cursor="Hand" FontWeight="SemiBold"/>
                                            </Grid>
                                        </Border>
                                        <!-- Content -->
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Left Menu -->
                                            <Border BorderBrush="#E5E7EB" BorderThickness="0,0,1,0" Background="#F9FAFB">
                                                <ListBox ItemsSource="{Binding FilterGroups}" SelectedItem="{Binding SelectedFilterGroup}" Background="Transparent" BorderThickness="0" Margin="0,5">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ColumnName}" Padding="10,6" Foreground="#4B5563" FontWeight="Medium"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsSelected" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                                                                <Setter TargetName="Bd" Property="BorderThickness" Value="3,0,0,0"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                </ListBox>
                                            </Border>
                                            <!-- Right Checkboxes -->
                                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding SelectedFilterGroup.Items}" Margin="15,10">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,5" Foreground="#374151" FontSize="12"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Popup>
                            
                        </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="ForcesGrid" Grid.Row="1" ItemsSource="{Binding ForcesView}" AutoGenerateColumns="False" 
                  CanUserAddRows="False" CanUserDeleteRows="True" CanUserSortColumns="True"
                  Style="{StaticResource StandardDataGridStyle}"
                  MinColumnWidth="90" Margin="16,16,16,0"
                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.CanContentScroll="True"
                  VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" EnableRowVirtualization="True" EnableColumnVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Story" Binding="{Binding Story}" />
                <DataGridTextColumn Header="Pier" Binding="{Binding Pier}" />
                <DataGridTextColumn Header="Output Case" Binding="{Binding OutputCase}" />
                <DataGridTextColumn Header="Location" Binding="{Binding Location}" />
                <DataGridTextColumn Header="P" Binding="{Binding P}" />
                <DataGridTextColumn Header="V2" Binding="{Binding V2}" />
                <DataGridTextColumn Header="V3" Binding="{Binding V3}" />
                <DataGridTextColumn Header="T" Binding="{Binding T}" />
                <DataGridTextColumn Header="M2" Binding="{Binding M2}" />
                <DataGridTextColumn Header="M3" Binding="{Binding M3}" />
            </DataGrid.Columns>
            <DataGrid.CommandBindings>
                <CommandBinding Command="ApplicationCommands.Paste" Executed="PasteCommand_Executed" />
            </DataGrid.CommandBindings>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="ApplicationCommands.Cut" Header="Cut" CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <MenuItem Command="ApplicationCommands.Copy" Header="Copy" CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <MenuItem Command="ApplicationCommands.Paste" Header="Paste" CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- Loading Overlay -->
        <Border Grid.Row="1" Background="#80FFFFFF" Visibility="{Binding IsFiltering, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="16,16,16,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Filtering Data..." FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBlueBrush}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,16,16,16">
            <Button Content="Save Changes" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryActionButtonStyle}" Margin="0,0,10,0" Width="120" Height="30"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource ActionButtonStyle}" Width="120" Height="30" />
        </StackPanel>
    </Grid>
</Window>
