<UserControl x:Class="PrecastConnectionApp.Views.DesignWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PrecastConnectionApp.Converters"
             xmlns:oxy="http://oxyplot.org/wpf"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:BoolToSafeBgConverter x:Key="BoolToSafeBgConverter"/>
        <local:BoolToSafeBrushConverter x:Key="BoolToSafeBrushConverter"/>
        <local:BoolToSafeTextConverter x:Key="BoolToSafeTextConverter"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
    </UserControl.Resources>
    <Grid Margin="20" MaxWidth="1320" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <StackPanel Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Command="{Binding BackCommand}" Background="Transparent" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" Padding="6" CornerRadius="6">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource Theme.Muted}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontSize="24" FontWeight="SemiBold" FontFamily="Space Grotesk" Foreground="{StaticResource Theme.Ink}" Margin="0,0,0,4">
                        <Run Text="{Binding SelectedPierLabel}"/>
                        <Run Text=" · " Foreground="{StaticResource Theme.Muted}" FontWeight="Normal"/>
                        <Run Text="{Binding SelectedStory}" Foreground="{StaticResource Theme.Muted}" FontWeight="Normal"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="{StaticResource Theme.Muted}">
                        <Run Text="{Binding CurrentWall.Section.Width, Mode=OneWay}"/>
                        <Run Text=" × "/>
                        <Run Text="{Binding CurrentWall.Section.Depth, Mode=OneWay}"/>
                        <Run Text=" mm · M"/>
                        <Run Text="{Binding CurrentWall.Section.Fck, Mode=OneWay}"/>
                        <Run Text=" / Fe"/>
                        <Run Text="{Binding CurrentWall.Section.Fy, Mode=OneWay}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding CurrentWall.LoadCombinations.Count, Mode=OneWay}"/>
                        <Run Text=" load combinations"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Export Calc Sheet (PDF)" Command="{Binding ExportPdfCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0,5,10,5"/>
                    <Button Content="Add to Summary" Command="{Binding ConfirmDesignCommand}" Style="{StaticResource PrimaryActionButtonStyle}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Main Workspace Two Columns -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="500"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Inputs & Data -->
                <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0" MaxHeight="{Binding ActualHeight, ElementName=RightColumnBorder}">
                    <StackPanel Margin="0,0,8,0">

                        <!-- Section Geometry Panel -->
                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                            <StackPanel>
                                <!-- Panel Header -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12" Background="Transparent">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Section geometry &amp; reinforcement" FontSize="14" FontWeight="SemiBold" FontFamily="Space Grotesk"/>
                                        <TextBlock Text="Confirm dimensions before generating curve" FontSize="12" Foreground="{StaticResource Theme.Muted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Panel Body -->
                                <Grid Margin="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Row 0 -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Width (B)" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="mm" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBox Text="{Binding CurrentWall.Section.Width, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Depth (D)" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="mm" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBox Text="{Binding CurrentWall.Section.Depth, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Clear cover" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="mm" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBox Text="{Binding CurrentWall.Section.ClearCover, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                    </StackPanel>

                                    <!-- Row 1 -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Bars - depth face" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="No's" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBox Text="{Binding CurrentWall.Section.NumMajorBars, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Bars - width face" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="No's" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBox Text="{Binding CurrentWall.Section.NumMinorBars, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Grade - fck" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="MPa" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBox Text="{Binding CurrentWall.Section.Fck, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                    </StackPanel>

                                    <!-- Row 2 -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Grade - fy" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="MPa" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <ComboBox SelectedValue="{Binding CurrentWall.Section.Fy, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Style="{StaticResource {x:Type ComboBox}}" Width="160" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="415"/>
                                            <ComboBoxItem Content="500"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,10,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Height of wall" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="mm" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBox Text="{Binding CurrentWall.Section.Height, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Keff" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBox Text="{Binding CurrentWall.Section.Keff, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                    </StackPanel>

                                    <!-- Row 3 -->
                                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,12">
                                        <Grid Margin="0,0,0,4" Width="160" HorizontalAlignment="Left">
                                            <TextBlock Text="Percentage of steel (Pt)" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                            <TextBlock Text="%" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBox Text="{Binding CurrentWall.Section.PercentageSteel, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                    </StackPanel>

                                    <!-- Row 4: Action Button -->
                                    <Button Grid.Row="3" Grid.Column="3" Content="Perform Calculations" Command="{Binding RunCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}" Width="160" HorizontalAlignment="Left" Margin="0,15,0,15"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Design Pipeline Panel -->
                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                            <StackPanel>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12" Background="Transparent">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Design pipeline" FontSize="14" FontWeight="SemiBold" FontFamily="Space Grotesk"/>
                                        <TextBlock Text="Review calculation progress" FontSize="12" Foreground="{StaticResource Theme.Muted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ItemsControl ItemsSource="{Binding DesignPipeline}" Margin="16,12">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="20" Height="20" CornerRadius="10" BorderThickness="1" Margin="0,0,10,0" VerticalAlignment="Top"
                                                    Background="{Binding IsDone, Converter={StaticResource BoolToSafeBgConverter}}"
                                                    BorderBrush="{Binding IsDone, Converter={StaticResource BoolToSafeBrushConverter}}">
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                                                           Foreground="{Binding IsDone, Converter={StaticResource BoolToSafeBrushConverter}}" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding IsDone, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="{Binding IsActive, Converter={StaticResource BoolToFontWeightConverter}, FallbackValue=Normal}"/>
                                                    <TextBlock Text="{Binding Desc}" FontSize="11" Foreground="{StaticResource Theme.Muted}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Load Combinations Panel -->
                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                            <StackPanel>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Load combinations" FontSize="14" FontWeight="SemiBold" FontFamily="Space Grotesk"/>
                                        <TextBlock Text="Click a row to set it as the active demand point on the interaction curve" FontSize="12" Foreground="{StaticResource Theme.Muted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="16,12,16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Safe / Total Count -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SafeCombinationsCount, StringFormat='SAFE: {0}'}" FontSize="10" FontWeight="SemiBold" Foreground="#166534" Margin="0,0,8,0"/>
                                        <TextBlock Text="/" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding TotalCombinationsCount, StringFormat='TOTAL: {0}'}" FontSize="10" FontWeight="SemiBold" Foreground="#4B5563"/>
                                    </StackPanel>

                                    <!-- Search and Filter -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="White" BorderBrush="#A0A0A0" BorderThickness="1" CornerRadius="4" Margin="0,0,8,0" Padding="6,2" Height="30">
                                            <StackPanel Orientation="Horizontal">
                                                <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Ellipse Canvas.Left="4" Canvas.Top="4" Width="14" Height="14" 
                                                                 Stroke="#9CA3AF" StrokeThickness="2" Fill="Transparent"/>
                                                        <Line X1="21" Y1="21" X2="16.65" Y2="16.65" 
                                                              Stroke="#9CA3AF" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                    </Canvas>
                                                </Viewbox>
                                                
                                                <Grid VerticalAlignment="Center" Margin="0,0,0,1">
                                                    <TextBlock Text="Search combinations..." Foreground="#9CA3AF" FontSize="12" IsHitTestVisible="False" VerticalAlignment="Center" Margin="2,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox x:Name="SearchTextBox" Background="Transparent" BorderThickness="0" Width="150" FontSize="12" Foreground="#374151" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Button x:Name="FilterButton" Command="{Binding ToggleFilterPopupCommand}" Style="{StaticResource ActionButtonStyle}" FontSize="12" Padding="11,5" Height="30" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M4,6 H20 M8,12 H16 M11,18 H13" 
                                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="Filter" VerticalAlignment="Center" FontWeight="Medium"/>
                                            </StackPanel>
                                        </Button>

                                        <Popup x:Name="FilterPopup" IsOpen="{Binding IsFilterPopupOpen}" StaysOpen="False" PlacementTarget="{Binding ElementName=FilterButton}" Placement="Bottom" HorizontalOffset="-100" VerticalOffset="8" AllowsTransparency="True">
                                            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Margin="0,0,15,15">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="12" Direction="270" ShadowDepth="4"/>
                                                </Border.Effect>
                                                <StackPanel Width="150" Margin="15,10">
                                                    <TextBlock Text="Filter by Status" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,10"/>
                                                    <RadioButton Content="All" IsChecked="{Binding IsFilterAll}" Margin="0,0,0,5" GroupName="StatusFilter"/>
                                                    <RadioButton Content="Safe" IsChecked="{Binding IsFilterSafe}" Margin="0,0,0,5" GroupName="StatusFilter"/>
                                                    <RadioButton Content="Unsafe" IsChecked="{Binding IsFilterUnsafe}" Margin="0,0,0,5" GroupName="StatusFilter"/>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </StackPanel>
                                </Grid>

                                <DataGrid ItemsSource="{Binding LoadCombinationsView}" 
                                      SelectedItem="{Binding SelectedLoadCombination, Mode=TwoWay}"
                                      AutoGenerateColumns="False" IsReadOnly="True" 
                                      Style="{StaticResource StandardDataGridStyle}" Background="Transparent"
                                      HeadersVisibility="Column" GridLinesVisibility="All" RowHeight="40" BorderThickness="0"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" CanUserSortColumns="True"
                                      MinHeight="100" MaxHeight="350" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Combination" Binding="{Binding OutputCase}" Width="1.5*" />
                                        <DataGridTextColumn Header="Pu (kN)" Binding="{Binding P, StringFormat={}{0:F1}}" Width="*" />
                                        <DataGridTextColumn Header="Mu2 (kNm)" Binding="{Binding M2, StringFormat={}{0:F2}}" Width="*" />
                                        <DataGridTextColumn Header="Mu3 (kNm)" Binding="{Binding M3, StringFormat={}{0:F2}}" Width="*" />
                                        <DataGridTextColumn Header="Cap. M" Binding="{Binding FinalM3, StringFormat={}{0:F2}}" Width="*" />
                                        <DataGridTextColumn Header="Ratio" Binding="{Binding Ratio, StringFormat={}{0:F2}}" Width="*" />
                                        <!-- Status Column using a DataTemplate to show SAFE/UNSAFE pills -->
                                        <DataGridTemplateColumn Header="Status" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        Background="{Binding IsSafe, Converter={StaticResource BoolToSafeBgConverter}}"
                                                        BorderBrush="{Binding IsSafe, Converter={StaticResource BoolToSafeBrushConverter}}" BorderThickness="1">
                                                        <TextBlock Text="{Binding IsSafe, Converter={StaticResource BoolToSafeTextConverter}}" 
                                                               Foreground="{Binding IsSafe, Converter={StaticResource BoolToSafeBrushConverter}}" 
                                                               FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Right Column: Interaction Plot -->
                <Border x:Name="RightColumnBorder" Grid.Row="0" Grid.Column="2" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16" VerticalAlignment="Top">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="400"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Plot Header -->
                        <StackPanel Grid.Row="0" Margin="16,16,16,10">
                            <TextBlock Text="Interaction diagram" FontSize="15" FontWeight="SemiBold" FontFamily="Space Grotesk"/>
                            <TextBlock Text="Normalized Pu–Mu envelope · IS 456" FontSize="12" Foreground="{StaticResource Theme.Muted}"/>
                        </StackPanel>

                        <!-- Axis Toggles -->
                        <Grid Grid.Row="1" Margin="16,0,16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- To make these real toggles, we'll use Buttons setting the bool in VM. 
                             Using a simplified ToggleButton logic or just Buttons for now. -->
                            <ToggleButton Grid.Column="0" Content="Major axis (M3)" IsChecked="{Binding IsMajorAxis}" 
                                      Height="30" FontSize="12" FontFamily="Space Grotesk" FontWeight="SemiBold"/>
                            <ToggleButton Grid.Column="2" Content="Minor axis (M2)" IsChecked="{Binding IsMajorAxis, Converter={StaticResource InverseBoolConverter}}" 
                                      Height="30" FontSize="12" FontFamily="Space Grotesk" FontWeight="SemiBold"/>
                        </Grid>

                        <!-- The Plot -->
                        <oxy:PlotView Grid.Row="2" Model="{Binding PlotModel}" Background="Transparent" Margin="10,0"/>

                        <!-- Plot Footer / Controls -->
                        <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Background="{StaticResource CardBrush}" CornerRadius="0,0,8,8">
                            <StackPanel Margin="16">
                                <!-- Slider Section -->
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Steel percentage — Pt provided" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Left" Foreground="{StaticResource Theme.Ink}"/>
                                    <TextBlock FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource Theme.Ink}">
                                    <Run Text="{Binding CurrentWall.FinalPt, StringFormat={}{0:F2}}" />
                                    <Run Text="%" Foreground="{StaticResource Theme.Muted}" FontSize="10"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Minimum="0.8" Maximum="4.0" Value="{Binding CurrentWall.FinalPt, UpdateSourceTrigger=PropertyChanged}" SmallChange="0.1" LargeChange="0.5" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentWall.Section.MainBarDia, StringFormat='Equivalent Main Bar Dia: {0:F1} mm'}" FontSize="11" Foreground="{StaticResource Theme.Muted}" Margin="0,0,0,12" HorizontalAlignment="Right"/>

                                <Border Background="#F3F4F6" CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
                                    <Grid>
                                        <TextBlock Text="Calculate minimum safe Pt for this combination" FontSize="11" Foreground="{StaticResource Theme.Muted}" VerticalAlignment="Center"/>
                                        <Button Content="Apply" Command="{Binding RecommendPtCommand}" HorizontalAlignment="Right" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Padding="12,4" FontSize="11" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{StaticResource Theme.Ink}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
        
                <!-- Finalize Steel Percentage Panel -->
                <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
            <StackPanel>
                <!-- Header -->
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Finalize steel percentage" FontSize="14" FontWeight="SemiBold" FontFamily="Space Grotesk"/>
                        <TextBlock Text="Confirm Pt and safety status for the design summary" FontSize="12" Foreground="{StaticResource Theme.Muted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Body -->
                <StackPanel Margin="16">
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Pt provided" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Left" />
                                <TextBlock Text="%" FontSize="11" Foreground="{StaticResource Theme.Muted}" HorizontalAlignment="Right" />
                            </Grid>
                            <TextBox Text="{Binding CurrentWall.FinalPt, StringFormat={}{0:F2}}" IsReadOnly="True" Background="#F9FAFB" Foreground="{StaticResource Theme.Muted}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Governing interaction ratio" FontSize="11" Foreground="{StaticResource Theme.Muted}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedLoadCombination.Ratio, StringFormat={}{0:F2}}" IsReadOnly="True" Background="#F9FAFB" Foreground="{StaticResource Theme.Muted}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Status" FontSize="11" Foreground="{StaticResource Theme.Muted}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding CurrentWall.LoadCombinations[0].IsSafe, Converter={StaticResource BoolToSafeTextConverter}}" IsReadOnly="True" Background="#F9FAFB" Foreground="{Binding CurrentWall.LoadCombinations[0].IsSafe, Converter={StaticResource BoolToSafeBrushConverter}}" FontWeight="SemiBold" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8" FontFamily="Consolas"/>
                        </StackPanel>
                    </Grid>

                    <!-- Warning for Unsafe Status -->
                    <Border Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,16"
                            Visibility="{Binding ShowOverridePanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="•" Foreground="#D97706" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Top"/>
                            <TextBlock Text="The selected combination exceeds capacity at the current Pt. Apply the recommended Pt above, increase section size, or override with an engineering note if a different load path governs (e.g. this combination is excluded per project basis-of-design)." 
                                       Foreground="#B45309" FontSize="11.5" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding ConfirmDesignCommand}" Style="{StaticResource PrimaryActionButtonStyle}" Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Confirm Pt and add to summary" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ToggleOverrideCommand}" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Foreground="{StaticResource Theme.Ink}" Padding="16,8" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Override with note" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
