<Window x:Class="PrecastConnectionApp.Views.ProjectInformationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Information" Height="500" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Theme.Paper}"
        FontFamily="Segoe UI">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                
                <GroupBox Header="Project Details" BorderBrush="{StaticResource Theme.Line}" Foreground="{StaticResource Theme.Ink}" Margin="0,0,0,10" Padding="15,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Project Number *" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme.Muted}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProjectNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource InputBox}" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Project Name *" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme.Muted}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource InputBox}" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Location *" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme.Muted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource InputBox}" HorizontalAlignment="Stretch" Margin="0,0,0,0"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="External Parties" BorderBrush="{StaticResource Theme.Line}" Foreground="{StaticResource Theme.Ink}" Margin="0,0,0,10" Padding="15,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Client" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme.Muted}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Client, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputBox}" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Contractor" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme.Muted}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Contractor, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputBox}" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Consultant" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme.Muted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Consultant, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputBox}" HorizontalAlignment="Stretch" Margin="0,0,0,0"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Internal Team" BorderBrush="{StaticResource Theme.Line}" Foreground="{StaticResource Theme.Ink}" Margin="0,0,0,5" Padding="15,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Designed By" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme.Muted}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DesignedBy, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputBox}" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Checked By" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme.Muted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CheckedBy, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputBox}" HorizontalAlignment="Stretch" Margin="0,0,0,0"/>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryActionButtonStyle}" Margin="0,5,10,5"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource ActionButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
