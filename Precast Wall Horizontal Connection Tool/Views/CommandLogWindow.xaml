<Window x:Class="PrecastConnectionApp.Views.CommandLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PrecastConnectionApp.Views"
        xmlns:viewmodels="clr-namespace:PrecastConnectionApp.ViewModels;assembly=PrecastConnectionApp.Core"
        Title="Command Log" Height="450" Width="600" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Theme.Paper}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Project Command Log" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Theme.Ink}" Margin="0,0,0,10"/>
        
        <Border Grid.Row="1" Background="{StaticResource Theme.PaperPanel}" BorderBrush="{StaticResource Theme.Line}" BorderThickness="1" CornerRadius="4" Padding="10">
            <TextBox Text="{Binding Source={x:Static viewmodels:StatusNotifier.Instance}, Path=CommandLog, Mode=OneWay}" 
                     FontSize="12" FontFamily="Consolas" Foreground="{StaticResource Theme.Ink}" 
                     Background="Transparent" BorderThickness="0" IsReadOnly="True" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto" TextChanged="CommandLog_TextChanged" />
        </Border>

        <Button Grid.Row="2" Content="Close" Width="100" HorizontalAlignment="Right" Margin="0,15,0,0" Padding="0,6" 
                Background="{StaticResource Theme.PaperPanel}" BorderBrush="{StaticResource Theme.Line}" BorderThickness="1"
                Click="CloseButton_Click" Cursor="Hand" />
    </Grid>
</Window>
