<Window x:Class="PrecastConnectionApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PrecastConnectionApp"
        xmlns:viewmodels="clr-namespace:PrecastConnectionApp.ViewModels"
        xmlns:coreviewmodels="clr-namespace:PrecastConnectionApp.ViewModels;assembly=PrecastConnectionApp.Core"
        xmlns:views="clr-namespace:PrecastConnectionApp.Views"
        mc:Ignorable="d"
        Title="Precast Wall Connection Tool" Height="720" Width="1280" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" WindowState="Maximized"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsCommand}"/>
    </Window.InputBindings>

    <Grid Background="{DynamicResource Theme.Paper}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="Margin" Value="8" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Option 2: Unified Title & Menu Bar -->
        <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}" BorderBrush="{StaticResource TitleBarBorderBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Logo -->
                <Image Grid.Column="0" Source="pack://application:,,,/POSSIBUILD.ico" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                
                <!-- App Title -->
                <TextBlock Grid.Column="1" Text="Precast Wall Connection Tool" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Foreground="{StaticResource MenuTextBrush}" Margin="0,0,20,0"/>

                <!-- Standard Menu Bar -->
                <Menu Grid.Column="2" HorizontalAlignment="Left" Background="Transparent" Foreground="{StaticResource MenuTextBrush}" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True" FontSize="13">
                    <MenuItem Header="File">
                        <MenuItem Header="New Project" Command="{Binding NewProjectCommand}" InputGestureText="Ctrl+N" />
                        <MenuItem Header="Open Project" Command="{Binding OpenProjectCommand}" InputGestureText="Ctrl+O" />
                        <Separator/>
                        <MenuItem Header="Save" Command="{Binding SaveProjectCommand}" InputGestureText="Ctrl+S" />
                        <MenuItem Header="Save As..." Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S" />
                        <Separator/>
                        <MenuItem Header="Edit Project Information" Command="{Binding EditProjectInformationCommand}" />
                        <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
                    </MenuItem>
                    <MenuItem Header="Edit">
                        <MenuItem Header="Undo" />
                        <MenuItem Header="Redo" />
                    </MenuItem>
                    <MenuItem Header="View">
                        <MenuItem Header="Dashboard" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" />
                    </MenuItem>
                    <MenuItem Header="Help">
                        <MenuItem Header="About" />
                    </MenuItem>
                </Menu>

                <!-- Window Controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Command="{Binding MinimizeCommand}" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Margin="0,0,10,0" Width="30" Height="30" Cursor="Hand"/>
                    <Button Command="{Binding MaximizeCommand}" Content="&#xE922;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Margin="0,0,10,0" Width="30" Height="30" Cursor="Hand"/>
                    <Button Command="{Binding CloseCommand}" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content (Tab Control) -->
        <Border Grid.Row="1" Background="{StaticResource PageBackgroundBrush}">
            <TabControl ItemsSource="{Binding Workspaces}" SelectedItem="{Binding SelectedWorkspace}" 
                        Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <!-- Add a bottom border to the tab strip area itself -->
                        <Setter Property="Margin" Value="0,0,0,0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </TabControl.Resources>
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Tab Strip with full bottom border -->
                            <Border Grid.Row="0" Background="{StaticResource TabStripBrush}" BorderBrush="{StaticResource TitleBarBorderBrush}" BorderThickness="0,0,0,1" Padding="10,5,10,0">
                                <TabPanel x:Name="HeaderPanel" IsItemsHost="true" Margin="0" Background="Transparent"/>
                            </Border>
                            <!-- Content -->
                            <ContentPresenter Grid.Row="1" x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="15,9"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Foreground" Value="{StaticResource MenuTextBrush}"/>
                        <Setter Property="FontSize" Value="12.5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder" Background="{TemplateBinding Background}" 
                                            BorderBrush="Transparent" 
                                            BorderThickness="1,1,1,0"
                                            CornerRadius="6,6,0,0"
                                            Margin="0,0,2,-1">
                                        <Grid>
                                            <!-- Top blue accent, only visible when selected -->
                                            <Border x:Name="TopAccent" Background="Transparent" Height="2" VerticalAlignment="Top" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                                            
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                              ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource ActiveTabBrush}"/>
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource TitleBarBorderBrush}"/>
                                            <Setter TargetName="TopAccent" Property="Background" Value="{StaticResource ActiveTabAccentBrush}"/>
                                            <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#111827"/>
                                            <Setter TargetName="ContentSite" Property="TextElement.FontWeight" Value="Medium"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="TabBorder" Property="Background" Value="#E5E7EB"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.ItemContainerStyle>
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}">
                            <ContentControl.Resources>
                                
                                <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
                                    <StackPanel Orientation="Horizontal" Margin="5,0">
                                        <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Rectangle Canvas.Left="3" Canvas.Top="3" Width="7" Height="7" RadiusX="1" RadiusY="1" 
                                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" StrokeThickness="1.8" Fill="Transparent"/>
                                                <Rectangle Canvas.Left="14" Canvas.Top="3" Width="7" Height="7" RadiusX="1" RadiusY="1" 
                                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" StrokeThickness="1.8" Fill="Transparent"/>
                                                <Rectangle Canvas.Left="3" Canvas.Top="14" Width="7" Height="7" RadiusX="1" RadiusY="1" 
                                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" StrokeThickness="1.8" Fill="Transparent"/>
                                                <Rectangle Canvas.Left="14" Canvas.Top="14" Width="7" Height="7" RadiusX="1" RadiusY="1" 
                                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" StrokeThickness="1.8" Fill="Transparent"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>

                                <DataTemplate DataType="{x:Type viewmodels:ProjectWorkspaceViewModel}">
                                    <StackPanel Orientation="Horizontal" Margin="5,0">
                                        <Viewbox Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M14,2 H6 a2,2 0 0 0 -2,2 v16 a2,2 0 0 0 2,2 h12 a2,2 0 0 0 2,-2 V8 z" 
                                                      Stroke="{StaticResource PrimaryBlueBrush}" StrokeThickness="2" Fill="Transparent"/>
                                                <Path Data="M14,2 L14,8 L20,8" 
                                                      Stroke="{StaticResource PrimaryBlueBrush}" StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Miter"/>
                                            </Canvas>
                                        </Viewbox>
                                        
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProjectName}" VerticalAlignment="Center"/>
                                            <TextBlock Text="*" Foreground="{StaticResource PrimaryBlueBrush}" FontWeight="Bold" FontSize="14" Margin="2,-2,0,0" VerticalAlignment="Center"
                                                       Visibility="{Binding IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </StackPanel>
                                        
                                        <Button Command="{Binding DataContext.CloseProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}"
                                                Content="✕" Background="Transparent" BorderThickness="0" Foreground="{StaticResource MenuTextBrush}" 
                                                FontSize="10" Margin="5,0,0,0" Cursor="Hand" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                                
                            </ContentControl.Resources>
                        </ContentControl>
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>
        </Border>

        <!-- Slim Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource StatusBarBrush}" BorderBrush="{StaticResource TitleBarBorderBrush}" BorderThickness="0,1,0,0" Padding="15,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Source={x:Static coreviewmodels:StatusNotifier.Instance}, Path=Message}" 
                           VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource MenuTextBrush}"/>
                
                <Button Grid.Column="1" Content="View Full Log" Command="{Binding ViewLogCommand}" 
                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource PrimaryBlueBrush}" 
                        FontSize="11" Cursor="Hand" VerticalAlignment="Center" Margin="10,0,0,0"
                        Visibility="{Binding IsProjectActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
